# Server configuration
PORT=3000

# Security - 32-byte (64 characters) hex key for encrypting OAuth tokens
# You can generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef

# YouTube (Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/youtube/callback

# Instagram / Facebook Graph API (Meta Developers)
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_REDIRECT_URI=http://localhost:3000/auth/instagram/callback

# Optional WordPress Integration (Web CMS)
WORDPRESS_URL=https://your-wordpress-site.com
WORDPRESS_USER=your-admin-username
WORDPRESS_APP_PASSWORD=your-wordpress-application-password
